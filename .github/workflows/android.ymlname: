
on:
  workflow_dispatch:

jobs:
  build:
    runs-on: ubuntu-latest

    steps:
      - name: Checkout Code
        uses: actions/checkout@v4

      - name: Create APK Folder
        run: |
          mkdir apk
          cp -r www apk/

      - name: Upload APK Files
        uses: actions/upload-artifact@v4
        with:
          name: BakraCalculator
          path: apk
